<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sfquorum.refresh</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/miguelmoncada/Documents/SF Votes/scripts/refresh-local.sh</string>
  </array>

  <!-- Run every day at 6:30am local time. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>6</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/miguelmoncada/Documents/SF Votes/.cache/launchd-refresh.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/miguelmoncada/Documents/SF Votes/.cache/launchd-refresh.log</string>

  <key>RunAtLoad</key>
  <false/>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
