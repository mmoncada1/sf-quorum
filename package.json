{
  "name": "sf-quorum",
  "version": "0.1.0",
  "private": true,
  "description": "SF Quorum — a public accountability portal tracking San Francisco Board of Supervisors legislation and voting records.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "ingest": "tsx scripts/ingest.ts",
    "enrich": "tsx scripts/enrich.ts",
    "compute": "tsx scripts/compute.ts",
    "refresh": "tsx scripts/ingest.ts && tsx scripts/enrich.ts && tsx scripts/compute.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/analytics": "^2.0.1",
    "cheerio": "^1.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
